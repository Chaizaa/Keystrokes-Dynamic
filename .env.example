# Flask Configuration
# Copy this file to .env and update values

# Flask Settings
FLASK_APP=app.py
FLASK_ENV=development
HOST=127.0.0.1
SECRET_KEY=your-secret-key-here-change-in-production

# Trusted public base URL used to build links in outgoing emails
# (password reset / verification). MUST be set in production: without it the
# link host is derived from the request Host/X-Forwarded-Host header, which an
# attacker can spoof to make reset links point at their own domain.
# Example: APP_BASE_URL=https://your-app.example.com
APP_BASE_URL=

# Database Configuration
DATABASE_TYPE=sqlite
DATABASE_PATH=data/biometric_auth.db

# PostgreSQL (if using)
# DATABASE_TYPE=postgresql
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Security Settings
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
PERMANENT_SESSION_LIFETIME=3600

# ML Model Settings
MIN_ENROLLMENT_SAMPLES=30
RECOMMENDED_SAMPLES=30
VERIFICATION_THRESHOLD=0.7
MAX_LOGIN_ATTEMPTS=5
# Active ML backend (mode switch): rf | svm
# Invalid values fallback to rf automatically.
# Keep rf for conservative rollout, switch to svm after staging validation.
# Note: ML_BACKEND only affects INTERNAL login flow. Partner API uses
# template-distance comparison and ignores this setting.
ML_BACKEND=rf

# Partner API decision threshold (0.0 - 1.0).
# Default 0.7 (Medium Confidence). Raise to 0.9 for strict-only access ("High Confidence").
PARTNER_DECISION_THRESHOLD=0.7

# API Rate Limiting
RATELIMIT_ENABLED=True
RATELIMIT_DEFAULT=100 per hour
RATELIMIT_STORAGE_URL=memory://

# Logging
LOG_LEVEL=INFO
LOG_FILE=app.log

# Mail (example for Gmail SMTP)
# Recommended: create an App Password (if using Google accounts with 2FA) and set MAIL_USERNAME and MAIL_PASSWORD
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER="SecureAuth <your@gmail.com>"
