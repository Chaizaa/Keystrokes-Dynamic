# Flask Configuration
# Copy this file to .env and update values

# Flask Settings
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-here-change-in-production

# Database Configuration
DATABASE_TYPE=sqlite
DATABASE_PATH=data/biometric_auth.db

# PostgreSQL (if using)
# DATABASE_TYPE=postgresql
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Security Settings
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
PERMANENT_SESSION_LIFETIME=3600

# ML Model Settings
MIN_ENROLLMENT_SAMPLES=20
VERIFICATION_THRESHOLD=0.7
MAX_LOGIN_ATTEMPTS=5
# Active ML backend (mode switch): rf | svm
# Invalid values fallback to rf automatically.
# Keep rf for conservative rollout, switch to svm after staging validation.
ML_BACKEND=rf

# API Rate Limiting
RATELIMIT_ENABLED=True
RATELIMIT_DEFAULT=100 per hour
RATELIMIT_STORAGE_URL=memory://

# Logging
LOG_LEVEL=INFO
LOG_FILE=app.log

# Mail (example for Gmail SMTP)
# Recommended: create an App Password (if using Google accounts with 2FA) and set MAIL_USERNAME and MAIL_PASSWORD
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER="SecureAuth <your@gmail.com>"
