        <mxCell id="analysis_label" value="6-CRITERIA ANALYSIS" style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="530" y="255" width="160" height="20" as="geometry" />
        </mxCell>

        <!-- Criteria 1 -->
        <mxCell id="criteria1" value="2. Length Check&#10;len(password) = 9 chars&#10;Score: +2 (8-15 chars)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeWidth=2;align=left;" vertex="1" parent="1">
          <mxGeometry x="540" y="290" width="240" height="60" as="geometry" />
        </mxCell>

        <!-- Criteria 2 -->
        <mxCell id="criteria2" value="3. Uppercase Check&#10;Regex: [A-Z]&#10;Match: 'M', 'P'&#10;Score: +2 (found)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeWidth=2;align=left;" vertex="1" parent="1">
          <mxGeometry x="540" y="365" width="240" height="70" as="geometry" />
        </mxCell>

        <!-- Criteria 3 -->
        <mxCell id="criteria3" value="4. Lowercase Check&#10;Regex: [a-z]&#10;Match: 'y', 's', 's'&#10;Score: +2 (found)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeWidth=2;align=left;" vertex="1" parent="1">
          <mxGeometry x="540" y="450" width="240" height="70" as="geometry" />
        </mxCell>

        <!-- Criteria 4 -->
        <mxCell id="criteria4" value="5. Digit Check&#10;Regex: [0-9]&#10;Match: '1', '2', '3'&#10;Score: +2 (found)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeWidth=2;align=left;" vertex="1" parent="1">
          <mxGeometry x="540" y="535" width="240" height="70" as="geometry" />
        </mxCell>

        <!-- Criteria 5 -->
        <mxCell id="criteria5" value="6. Special Char Check&#10;Regex: [!@#$%^&amp;*()_+\\-=\\[\\]{};':&quot;\\|,&lt;&gt;./?]&#10;Match: '@'&#10;Score: +2 (found)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeWidth=2;align=left;" vertex="1" parent="1">
          <mxGeometry x="540" y="620" width="240" height="80" as="geometry" />
        </mxCell>

        <!-- Criteria 6 -->
        <mxCell id="criteria6" value="7. Common Pattern Check&#10;Check: top1000.txt&#10;Match: NOT found&#10;Score: +2 (not common)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeWidth=2;align=left;" vertex="1" parent="1">
