        <mxCell id="result_box" value="8. Total Score Calculation&#10;Length(2) + Upper(2) + Lower(2) + &#10;Digit(2) + Special(2) + NotCommon(2)&#10;= 12 / 13 points&#10;&#10;Percentage: (12/13) × 100% = 92.3%&#10;&#10;Category: VERY STRONG 🟢" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeWidth=3;align=left;fontStyle=1;" vertex="1" parent="1">
